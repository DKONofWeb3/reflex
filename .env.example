──────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Duplicate this file and rename the copy to: .env.local
#   2. Fill in your PRIVATE_KEY (line 16)
#   3. Everything else below is already filled in — don't change unless needed
#   4. After Phase 2 deployment, paste your contract addresses (lines 24–28)
#
# ⚠️  NEVER commit .env.local to Git — it's already in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ─── Somnia Testnet Network (pre-filled — no changes needed) ──────────────────
SOMNIA_RPC_URL=https://dream-rpc.somnia.network
SOMNIA_WS_URL=wss://dream-rpc.somnia.network
SOMNIA_CHAIN_ID=50312

# ─── Your Deployer Wallet Private Key ─────────────────────────────────────────
# How to get it: MetaMask → click account name → Account Details → Export Private Key
# Keep the 0x prefix
PRIVATE_KEY=0b460da912f5519e1f38ebf95cfefeac5d9d56ab45ebd9b451fcc555831deddc

# ─── Contract Addresses (fill these in after Phase 2 deployment) ──────────────
# You'll get these addresses after running: npm run deploy
NEXT_PUBLIC_PRICE_FEED_ETH=
NEXT_PUBLIC_PRICE_FEED_BTC=
NEXT_PUBLIC_PRICE_FEED_SOMI=
NEXT_PUBLIC_PREDICTION_MARKET=
NEXT_PUBLIC_REACTIVITY_HOOK=

# ─── Frontend Config (pre-filled — no changes needed) ─────────────────────────
# NEXT_PUBLIC_ prefix means these are safe to read in the browser
NEXT_PUBLIC_CHAIN_ID=50312
NEXT_PUBLIC_RPC_URL=https://dream-rpc.somnia.network
NEXT_PUBLIC_WS_URL=wss://dream-rpc.somnia.network
NEXT_PUBLIC_EXPLORER_URL=https://somnia-testnet.socialscan.io
